# framure forge — environment configuration
# Copy to `.env` (or `.env.local`) and fill in as needed.

# Base URL of the FastAPI material-generation backend (AMD GPU service).
# Endpoints used: POST {url}/generate, GET {url}/health
# Leave unset or empty to use the built-in mock generator.
# Example: VITE_FORGE_API_URL=http://localhost:8000
VITE_FORGE_API_URL=https://traffic-raw-guides-strikes.trycloudflare.com
